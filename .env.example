# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://arogya:arogya123@localhost:5432/arogyamitra
SYNC_DATABASE_URL=postgresql://arogya:arogya123@localhost:5432/arogyamitra

# ─── JWT ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-very-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── AI ───────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ─── External APIs ────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_api_key_here
SPOONACULAR_API_KEY=your_spoonacular_api_key_here

# ─── Google Calendar OAuth ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/calendar/callback

# ─── App ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development
